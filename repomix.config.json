{
  "output": {
    "style": "markdown",
    "filePath": "custom-output.md",
    "removeComments": false,
    "showLineNumbers": true,
    "compress": true,
    "includeFullDirectoryStructure": true,
    "fileSummary": true,
    "removeEmptyLines": true,
    "topFilesLength": 10
  },
  "ignore": {
    "customPatterns": [
      "android/**",
      "ios/**",
      "web/**",
      "windows/**",
      "build/**",
      ".dart_tool/**",
      "**/*.png",
      "**/*.ico",
      "**/*.xml",
      "**/*.gradle*",
      ".metadata",
      "devtools_options.yaml",
      "pubspec.lock",
      "test/**"
    ],
    "useDefaultPatterns": true,
    "useGitignore": true
  }
}